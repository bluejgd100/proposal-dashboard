# Fabric SQL Connection (copy from pine-intelligence Azure app)
FABRIC_SQL_SERVER=your-server.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=your-database-name
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# App Authentication (format: user1:pass1:role,user2:pass2:role)
USERS=admin:yourpassword:admin

# Server
PORT=8080
